<UserControl
    x:Class="Idasen.SystemTray.Win11.Views.Controls.HotkeyDefinitionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="Root">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="32" />
            <ColumnDefinition Width="*" MinWidth="80" />
            <ColumnDefinition Width="*" MinWidth="90" />
            <ColumnDefinition Width="2*" MinWidth="220" />
        </Grid.ColumnDefinitions>

        <!-- Icon -->
        <ui:SymbolIcon Grid.Column="0"
                       MinWidth="32"
                       Symbol="{Binding Symbol, ElementName=Root}"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" />

        <!-- Label -->
        <Grid Grid.Column="1" MinWidth="80" Margin="0,0,5,0">
            <!-- Non-editable label (default) -->
            <Label HorizontalAlignment="Stretch"
                   Content="{Binding HotkeyName, ElementName=Root}"
                   ToolTip="{Binding HotkeyTooltip, ElementName=Root}"
                   VerticalAlignment="Center" 
                   Padding="5,0,5,0">
                <Label.Style>
                    <Style TargetType="Label">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditable, ElementName=Root}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Label.Style>
            </Label>

            <ui:TextBox HorizontalAlignment="Stretch"
                        Text="{Binding EditableName, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="{Binding HotkeyTooltip, ElementName=Root}"
                        VerticalAlignment="Center"
                        VerticalContentAlignment="Center"
                        MaxLength="50"
                        ClearButtonEnabled="False">
                <ui:TextBox.Style>
                    <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditable, ElementName=Root}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:TextBox.Style>
            </ui:TextBox>
        </Grid>

        <!-- Key ComboBox -->
        <ComboBox Grid.Column="2"
                  MinWidth="90"
                  MaxDropDownHeight="300"
                  HorizontalAlignment="Stretch"
                  ItemsSource="{Binding AvailableKeys, ElementName=Root}"
                  SelectedItem="{Binding SelectedKey, ElementName=Root, Mode=TwoWay}"
                  ToolTip="{Binding KeyTooltip, ElementName=Root}"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.VerticalScrollBarVisibility="Auto" />

        <!-- Modifier Checkboxes -->
        <Grid Grid.Column="3" 
              Margin="5,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="50" />
                <ColumnDefinition Width="*" MinWidth="45" />
                <ColumnDefinition Width="*" MinWidth="55" />
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0"
                      Content="Ctrl" 
                      HorizontalAlignment="Stretch"
                      IsChecked="{Binding IsControlChecked, ElementName=Root, Mode=TwoWay}" 
                      Margin="0,0,10,0" />
            <CheckBox Grid.Column="1"
                      Content="Alt" 
                      HorizontalAlignment="Stretch"
                      IsChecked="{Binding IsAltChecked, ElementName=Root, Mode=TwoWay}" 
                      Margin="0,0,10,0" />
            <CheckBox Grid.Column="2"
                      Content="Shift" 
                      HorizontalAlignment="Stretch"
                      IsChecked="{Binding IsShiftChecked, ElementName=Root, Mode=TwoWay}" />
        </Grid>
    </Grid>
</UserControl>
