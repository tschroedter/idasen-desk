<UserControl
    x:Class="Idasen.SystemTray.Win11.Views.Controls.DeskPositionControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    x:Name="Root">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="30" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ui:SymbolIcon Grid.Column="0" MinWidth="32"
                       Symbol="{Binding Symbol, ElementName=Root}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding IsSymbolVisible, ElementName=Root, Mode=TwoWay}" />

        <!-- Position Name Label/TextBox Grid -->
        <Grid Grid.Column="1" MinWidth="120" Margin="0,0,5,0"
              Visibility="{Binding IsPositionNameVisible, ElementName=Root, Mode=TwoWay}">
            <!-- Non-editable label (default) -->
            <Label HorizontalAlignment="Stretch"
                   Content="{Binding PositionName, ElementName=Root}"
                   VerticalAlignment="Center" 
                   Padding="5,0,5,0">
                <Label.Style>
                    <Style TargetType="Label">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditable, ElementName=Root}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Label.Style>
            </Label>

            <!-- Editable text box -->
            <ui:TextBox HorizontalAlignment="Stretch"
                        Text="{Binding EditableName, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        VerticalAlignment="Center"
                        VerticalContentAlignment="Center"
                        MaxLength="50"
                        ClearButtonEnabled="False">
                <ui:TextBox.Style>
                    <Style TargetType="ui:TextBox" BasedOn="{StaticResource {x:Type ui:TextBox}}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditable, ElementName=Root}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:TextBox.Style>
            </ui:TextBox>
        </Grid>

        <Slider Grid.Column="2" Minimum="{Binding Minimum, ElementName=Root}"
                Maximum="{Binding Maximum, ElementName=Root}"
                Value="{Binding PositionValue, ElementName=Root, Mode=TwoWay}" TickPlacement="Both"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalAlignment="Center"
                VerticalContentAlignment="Center"
                PreviewKeyDown="OnSliderPreviewKeyDown"
                Focusable="True" />
        <StackPanel Grid.Column="3"
                    Margin="5,0,5,0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <Button Click="OnIncreaseClicked"
                    Padding="0"
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    ToolTip="Increase">
                <ui:SymbolIcon Symbol="{x:Static ui:SymbolRegular.ChevronUp12}" />
            </Button>
            <Button Click="OnDecreaseClicked"
                    Padding="0"
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    ToolTip="Decrease">
                <ui:SymbolIcon Symbol="{x:Static ui:SymbolRegular.ChevronDown12}" />
            </Button>
        </StackPanel>
        <TextBlock Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Right"
                   Text="{Binding PositionValue, ElementName=Root, StringFormat='0'}"
                   Padding="5,0,5,0" />
        <Label Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Right"
               Content="{Binding Units, ElementName=Root, Mode=OneWay}" />
        <CheckBox Grid.Column="6" VerticalAlignment="Center" MinWidth="75"
                  Content="Tray" ToolTip="Show in tray context menu"
                  IsChecked="{Binding IsVisibleInContextMenu, ElementName=Root, Mode=TwoWay}"
                  Visibility="{Binding IsShowInTrayVisible, ElementName=Root, Mode=TwoWay}" />
    </Grid>
</UserControl>